rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isChatParticipant() {
      return isSignedIn()
             && request.auth.uid in resource.data.participants;
    }

    function isChatParticipantById(chatId) {
      return isSignedIn()
             && exists(/databases/$(database)/documents/chats/$(chatId))
             && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    function isValidChatCreate() {
      return isSignedIn()
             && request.resource.data.keys().hasOnly([
               'buyerId',
               'sellerId',
               'productId',
               'productTitle',
               'participants',
               'lastMessage',
               'lastUpdated'
             ])
             && request.resource.data.keys().hasAll([
               'buyerId',
               'sellerId',
               'productId',
               'productTitle',
               'participants',
               'lastMessage',
               'lastUpdated'
             ])
             && request.resource.data.buyerId is string
             && request.resource.data.sellerId is string
             && request.resource.data.productId is string
             && request.resource.data.productTitle is string
             && request.resource.data.productTitle.size() > 0
             && request.resource.data.productTitle.size() <= 140
             && request.resource.data.participants is list
             && request.resource.data.participants.size() == 2
             && request.resource.data.participants.hasAll([
               request.resource.data.buyerId,
               request.resource.data.sellerId
             ])
             && request.resource.data.buyerId != request.resource.data.sellerId
             && request.auth.uid in request.resource.data.participants
             && exists(/databases/$(database)/documents/products/$(request.resource.data.productId))
             && get(/databases/$(database)/documents/products/$(request.resource.data.productId)).data.userId == request.resource.data.sellerId
             && request.resource.data.lastMessage == ''
             && request.resource.data.lastUpdated == request.time;
    }

    function isValidChatUpdate() {
      return isChatParticipant()
             && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
               'lastMessage',
               'lastUpdated'
             ])
             && request.resource.data.buyerId == resource.data.buyerId
             && request.resource.data.sellerId == resource.data.sellerId
             && request.resource.data.productId == resource.data.productId
             && request.resource.data.productTitle == resource.data.productTitle
             && request.resource.data.participants == resource.data.participants
             && request.resource.data.lastMessage is string
             && request.resource.data.lastMessage.size() > 0
             && request.resource.data.lastMessage.size() <= 500
             && request.resource.data.lastUpdated == request.time;
    }

    function isValidMessageCreate(chatId) {
      return isChatParticipantById(chatId)
             && request.resource.data.keys().hasOnly([
               'senderId',
               'text',
               'createdAt'
             ])
             && request.resource.data.keys().hasAll([
               'senderId',
               'text',
               'createdAt'
             ])
             && request.resource.data.senderId == request.auth.uid
             && request.resource.data.text is string
             && request.resource.data.text.size() > 0
             && request.resource.data.text.size() <= 500
             && request.resource.data.createdAt == request.time;
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    match /users/{userId} {
      allow read: if request.auth != null
                  && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow write: if request.auth != null
                   && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    match /savedProducts/{savedId} {
      allow read, write: if request.auth != null;
    }

    match /chats/{chatId} {
      allow get: if isSignedIn()
                 && (!exists(/databases/$(database)/documents/chats/$(chatId))
                     || isChatParticipant());
      allow list: if isChatParticipant();
      allow create: if isValidChatCreate();
      allow update: if isValidChatUpdate();
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isChatParticipantById(chatId);
        allow create: if isValidMessageCreate(chatId);
        allow update, delete: if false;
      }
    }
  }
}
